# Mercury Works — single source of truth for every credential + provider.
# Copy to .env and fill. NEVER commit .env (it's gitignored). Swapping a provider = editing ONE value here.
# On event day: paste whatever the sponsors give you, run scripts/smoke-test.sh, confirm all green.

# ─────────────────────────────────────────────────────────────
# LLM PROVIDER — the ONLY genuine day-of swap.
# Build/test on gemini (free). On the day, flip to openai + gpt-5.5.
# ─────────────────────────────────────────────────────────────
LLM_PROVIDER=gemini                 # gemini (free testing) | openai-api (event day)
LLM_MODEL=gemini-2.5-pro            # event day: gpt-5.6-sol  (provider id is "openai-api", model "gpt-5.6-sol")

# OpenAI (event credits attach to YOUR org key — no key swap, budget just appears)
OPENAI_API_KEY=
OPENAI_BASE_URL=                    # leave blank; event day optionally set to Cloudflare AI Gateway path

# Google Gemini (FREE key from https://aistudio.google.com/apikey — NOT the Gemini Pro app)
GOOGLE_API_KEY=

# ─────────────────────────────────────────────────────────────
# SPONSORS — you use YOUR OWN account throughout; free tiers cover the demo.
# Nothing to swap here unless a sponsor hands you a replacement key.
# ─────────────────────────────────────────────────────────────
# Convex (DB + spine) — from `npx convex dev`
CONVEX_URL=
CONVEX_DEPLOY_KEY=
CONVEX_REPORT_URL=                  # https://<deployment>.convex.site/report  (httpAction)

# Linkup (cited web search) — free key at https://app.linkup.so
LINKUP_API_KEY=

# ElevenLabs (voice) — key from https://elevenlabs.io ; model eleven_flash_v2_5
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Dodo Payments (payments) — test keys from app.dodopayments.com (toggle Test Mode → Developer → API Keys); also pre-create a product (pdt_) + webhook signing secret (whsec_)
DODO_PAYMENTS_API_KEY=
DODO_PAYMENTS_WEBHOOK_KEY=

# Cloudflare (Pages deploy + AI Gateway) — `npx wrangler login`
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CF_AI_GATEWAY_ID=                   # optional, for the live OpenAI cost dashboard

# ─────────────────────────────────────────────────────────────
# HERMES (personal laptop only) — the local runtime
# ─────────────────────────────────────────────────────────────
HERMES_API_URL=http://localhost:8642
API_SERVER_KEY=                     # set a STRONG random value on personal
HERMES_LANGFUSE_PUBLIC_KEY=
HERMES_LANGFUSE_SECRET_KEY=
HERMES_LANGFUSE_BASE_URL=https://cloud.langfuse.com
